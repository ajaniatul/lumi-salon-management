// =============================================================
// ELYSIAN SALON MANAGEMENT — PRISMA SCHEMA
// Full database schema covering all 20 modules
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  RECEPTIONIST
  STYLIST
}

enum AppointmentStatus {
  CONFIRMED
  WAITING
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  SPLIT
  MEMBERSHIP
  LOYALTY
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MembershipTier {
  SILVER
  GOLD
  PLATINUM
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  DAMAGED
  ADJUSTMENT
  PURCHASE_RETURN
  SALE_RETURN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  COMPENSATORY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum CommissionType {
  FIXED_PERCENTAGE
  SERVICE_BASED
  PRODUCT_BASED
}

enum ExpenseCategory {
  RENT
  SALARY
  ELECTRICITY
  WATER
  MARKETING
  SUPPLIES
  MAINTENANCE
  EQUIPMENT
  MISCELLANEOUS
}

enum ServiceCategory {
  HAIR
  SKIN
  NAILS
  MAKEUP
  BODY
  BRIDAL
  KIDS
  WELLNESS
}

enum ProductCategory {
  HAIR_CARE
  SKIN_CARE
  NAIL_CARE
  MAKEUP
  TOOLS
  ACCESSORIES
  CONSUMABLES
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ─────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?   @unique
  name         String
  passwordHash String
  role         Role      @default(RECEPTIONIST)
  avatar       String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  staff     Staff?
  sessions  Session[]
  auditLogs AuditLog[]

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────

model Customer {
  id               String    @id @default(cuid())
  customerId       String    @unique // CUS-0001 format
  name             String
  phone            String    @unique
  email            String?
  dateOfBirth      DateTime?
  gender           Gender?
  anniversary      DateTime?
  address          String?
  notes            String?
  loyaltyPoints    Int       @default(0)
  totalVisits      Int       @default(0)
  totalSpend       Decimal   @default(0) @db.Decimal(12, 2)
  preferredStaffId String?
  tags             String[]
  referredBy       String?   // customer ID who referred
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  preferredStaff      Staff?               @relation("PreferredStaff", fields: [preferredStaffId], references: [id])
  appointments        Appointment[]
  invoices            Invoice[]
  membership          CustomerMembership?
  packages            CustomerPackage[]
  loyaltyTransactions LoyaltyTransaction[]
  notifications       Notification[]

  @@index([phone])
  @@index([name])
  @@index([customerId])
}

// ─────────────────────────────────────────────
// STAFF / EMPLOYEE
// ─────────────────────────────────────────────

model Staff {
  id              String    @id @default(cuid())
  employeeId      String    @unique // EMP-001 format
  userId          String    @unique
  name            String
  phone           String    @unique
  email           String?
  designation     String    // Stylist, Senior Stylist, Colorist, Makeup Artist, etc.
  specializations String[]  // ["Hair Coloring", "Keratin", "Bridal Makeup"]
  salary          Decimal   @db.Decimal(10, 2)
  joiningDate     DateTime
  avatar          String?
  bio             String?
  rating          Decimal?  @db.Decimal(2, 1) // manager-set, 0.0–5.0
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user               User               @relation(fields: [userId], references: [id])
  appointments       Appointment[]
  attendance         Attendance[]
  leaves             Leave[]
  commissions        Commission[]
  commissionSettings CommissionSetting[]
  preferredByCustomers Customer[]        @relation("PreferredStaff")

  @@index([employeeId])
}

// ─────────────────────────────────────────────
// SERVICE
// ─────────────────────────────────────────────

model Service {
  id          String          @id @default(cuid())
  serviceCode String          @unique // SRV-001
  name        String
  description String?
  category    String          // e.g. HAIR, SKIN, NAILS – admin-configurable
  price       Decimal         @db.Decimal(10, 2)
  duration    Int             // minutes
  gstRate     Decimal         @default(18) @db.Decimal(5, 2)
  imageUrl    String?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  appointmentServices AppointmentService[]
  invoiceItems        InvoiceItem[]
  packageServices     PackageService[]
  commissionSettings  CommissionSetting[]

  @@index([category])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────────

model Product {
  id            String          @id @default(cuid())
  sku           String          @unique
  barcode       String?         @unique
  name          String
  description   String?
  category      String          // e.g. HAIR_CARE, SKIN_CARE – admin-configurable
  brand         String?
  price         Decimal         @db.Decimal(10, 2) // retail/sale price
  costPrice     Decimal         @db.Decimal(10, 2)
  mrp           Decimal?        @db.Decimal(10, 2)
  gstRate       Decimal         @default(18) @db.Decimal(5, 2)
  hsnCode       String?
  stockQuantity Int             @default(0)
  minStockLevel Int             @default(5)
  unit          String          @default("piece") // piece, ml, gm, etc.
  supplierId    String?
  manufacturingDate DateTime?
  expiryDate    DateTime?
  imageUrl      String?
  isActive      Boolean         @default(true)
  isForSale     Boolean         @default(true) // retail sale to customers
  isForUse      Boolean         @default(true) // used in services
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  supplier      Supplier?       @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]
  invoiceItems  InvoiceItem[]
  purchaseItems PurchaseItem[]
  commissionSettings CommissionSetting[]

  @@index([sku])
  @@index([category])
  @@index([isActive])
}

// ─────────────────────────────────────────────
// SUPPLIER
// ─────────────────────────────────────────────

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  gstin       String?
  bankAccount String?
  notes       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products  Product[]
  purchases Purchase[]
}

// ─────────────────────────────────────────────
// APPOINTMENT
// ─────────────────────────────────────────────

model Appointment {
  id            String            @id @default(cuid())
  appointmentNo String            @unique // APT-20240101-001
  customerId    String
  staffId       String
  date          DateTime          @db.Date
  startTime     DateTime
  endTime       DateTime
  duration      Int               // total minutes
  status        AppointmentStatus @default(CONFIRMED)
  notes         String?
  source        String?           // WALK_IN, WHATSAPP, PHONE, ONLINE
  reminderSent  Boolean           @default(false)
  cancelReason  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  customer Customer             @relation(fields: [customerId], references: [id])
  staff    Staff                @relation(fields: [staffId], references: [id])
  services AppointmentService[]
  invoice  Invoice?

  @@index([date])
  @@index([customerId])
  @@index([staffId])
  @@index([status])
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  price         Decimal     @db.Decimal(10, 2)
  duration      Int         // minutes

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])
}

// ─────────────────────────────────────────────
// INVOICE / BILLING
// ─────────────────────────────────────────────

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique // INV-2024-0001
  customerId      String
  appointmentId   String?       @unique
  subtotal        Decimal       @db.Decimal(12, 2)
  discountType    DiscountType?
  discountValue   Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2) // computed
  couponCode      String?
  couponDiscount  Decimal       @default(0) @db.Decimal(10, 2)
  taxableAmount   Decimal       @db.Decimal(12, 2)
  cgst            Decimal       @default(0) @db.Decimal(10, 2) // 9% of taxable
  sgst            Decimal       @default(0) @db.Decimal(10, 2) // 9% of taxable
  totalGst        Decimal       @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)
  dueAmount       Decimal       @default(0) @db.Decimal(12, 2)
  paymentStatus   PaymentStatus @default(PENDING)
  loyaltyUsed     Int           @default(0) // points redeemed
  loyaltyEarned   Int           @default(0) // points earned
  membershipUsed  Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  items       InvoiceItem[]
  payments    Payment[]

  @@index([customerId])
  @@index([invoiceNumber])
  @@index([paymentStatus])
  @@index([createdAt])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  itemType  String  // SERVICE | PRODUCT | PACKAGE
  serviceId String?
  productId String?
  name      String  // snapshot of name at time of billing
  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(10, 2)
  discount  Decimal @default(0) @db.Decimal(10, 2)
  gstRate   Decimal @db.Decimal(5, 2)
  gstAmount Decimal @db.Decimal(10, 2)
  total     Decimal @db.Decimal(10, 2) // after discount + tax

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id        String        @id @default(cuid())
  invoiceId String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  reference String?       // UPI ID, card last 4, transaction ID
  paidAt    DateTime      @default(now())
  notes     String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─────────────────────────────────────────────
// COUPON
// ─────────────────────────────────────────────

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal?     @db.Decimal(10, 2)
  maxDiscount    Decimal?     @db.Decimal(10, 2)
  usageLimit     Int?         // null = unlimited
  usedCount      Int          @default(0)
  validFrom      DateTime
  validUntil     DateTime
  applicableTo   String[]     // SERVICE, PRODUCT, ALL
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
}

// ─────────────────────────────────────────────
// INVENTORY & STOCK
// ─────────────────────────────────────────────

model StockMovement {
  id          String            @id @default(cuid())
  productId   String
  type        StockMovementType
  quantity    Int               // positive = in, negative = out
  beforeQty   Int
  afterQty    Int
  reason      String?
  reference   String?           // invoice no, purchase no, adjustment note
  createdBy   String?
  createdAt   DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// PURCHASE (Supplier Invoice)
// ─────────────────────────────────────────────

model Purchase {
  id              String    @id @default(cuid())
  purchaseNumber  String    @unique // PUR-2024-001
  supplierId      String?
  supplierName    String?   // free-text when no Supplier record
  supplierInvoice String?   // supplier's invoice number
  date            DateTime
  subtotal        Decimal   @db.Decimal(12, 2)
  gstAmount       Decimal   @db.Decimal(10, 2)
  totalAmount     Decimal   @db.Decimal(12, 2)
  paidAmount      Decimal   @default(0) @db.Decimal(12, 2)
  notes           String?
  receiptUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  supplier Supplier?      @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@index([date])
  @@index([supplierId])
}

model PurchaseItem {
  id          String  @id @default(cuid())
  purchaseId  String
  productId   String?
  description String?  // free-text item name when no product record
  quantity    Int
  costPrice   Decimal @db.Decimal(10, 2)
  gstRate     Decimal @db.Decimal(5, 2)
  gstAmount   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  purchase Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────
// EXPENSE
// ─────────────────────────────────────────────

model Expense {
  id            String          @id @default(cuid())
  category      ExpenseCategory
  description   String
  amount        Decimal         @db.Decimal(10, 2)
  gstAmount     Decimal?        @db.Decimal(10, 2)
  date          DateTime        @db.Date
  vendor        String?
  paymentMethod String?
  receiptUrl    String?
  notes         String?
  createdBy     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([date])
  @@index([category])
}

// ─────────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  staffId   String
  date      DateTime         @db.Date
  status    AttendanceStatus
  clockIn   DateTime?
  clockOut  DateTime?
  workHours Decimal?         @db.Decimal(5, 2)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@index([staffId])
  @@index([date])
}

model Leave {
  id          String      @id @default(cuid())
  staffId     String
  type        LeaveType
  fromDate    DateTime    @db.Date
  toDate      DateTime    @db.Date
  totalDays   Decimal     @db.Decimal(4, 1)
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  rejectedReason String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([staffId])
  @@index([status])
}

// ─────────────────────────────────────────────
// COMMISSION
// ─────────────────────────────────────────────

model CommissionSetting {
  id        String         @id @default(cuid())
  staffId   String
  type      CommissionType
  rate      Decimal        @db.Decimal(5, 2) // percentage
  serviceId String?        // null = all services
  productId String?        // null = all products
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())

  staff   Staff    @relation(fields: [staffId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
}

model Commission {
  id            String   @id @default(cuid())
  staffId       String
  month         Int      // 1–12
  year          Int
  serviceRevenue Decimal @default(0) @db.Decimal(12, 2)
  productRevenue Decimal @default(0) @db.Decimal(12, 2)
  commissionAmount Decimal @db.Decimal(10, 2)
  bonusAmount   Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount   Decimal  @db.Decimal(10, 2)
  isPaid        Boolean  @default(false)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, month, year])
  @@index([staffId])
}

// ─────────────────────────────────────────────
// MEMBERSHIP
// ─────────────────────────────────────────────

model Membership {
  id              String         @id @default(cuid())
  name            String         // "Silver", "Gold", "Platinum"
  tier            MembershipTier
  price           Decimal        @db.Decimal(10, 2)
  validityDays    Int
  discountPercent Decimal        @default(0) @db.Decimal(5, 2)
  benefits        String[]       // text descriptions
  freeServiceIds  String[]       // service IDs included free
  visitLimit      Int?           // null = unlimited
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customerMemberships CustomerMembership[]
}

model CustomerMembership {
  id            String    @id @default(cuid())
  customerId    String    @unique
  membershipId  String
  startDate     DateTime
  expiryDate    DateTime
  remainingVisits Int?
  invoiceId     String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer   Customer   @relation(fields: [customerId], references: [id])
  membership Membership @relation(fields: [membershipId], references: [id])

  @@index([expiryDate])
}

// ─────────────────────────────────────────────
// SERVICE PACKAGE
// ─────────────────────────────────────────────

model ServicePackage {
  id            String    @id @default(cuid())
  name          String
  description   String?
  category      String    @default("Hair")
  price         Decimal   @db.Decimal(10, 2)
  originalPrice Decimal?  @db.Decimal(10, 2)
  validityDays  Int
  serviceList   String[]  @default([])
  imageUrl      String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  services         PackageService[]
  customerPackages CustomerPackage[]
}

model PackageService {
  id        String @id @default(cuid())
  packageId String
  serviceId String
  sessions  Int    @default(1) // number of sessions included

  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service Service        @relation(fields: [serviceId], references: [id])
}

model CustomerPackage {
  id           String    @id @default(cuid())
  customerId   String
  packageId    String
  purchaseDate DateTime  @default(now())
  expiryDate   DateTime
  invoiceId    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  customer      Customer              @relation(fields: [customerId], references: [id])
  package       ServicePackage        @relation(fields: [packageId], references: [id])
  sessionUsages PackageSessionUsage[]

  @@index([customerId])
  @@index([expiryDate])
}

model PackageSessionUsage {
  id                String   @id @default(cuid())
  customerPackageId String
  serviceId         String
  usedAt            DateTime @default(now())
  invoiceId         String?
  staffId           String?

  customerPackage CustomerPackage @relation(fields: [customerPackageId], references: [id])

  @@index([customerPackageId])
}

// ─────────────────────────────────────────────
// LOYALTY PROGRAM
// ─────────────────────────────────────────────

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  customerId  String
  points      Int      // positive = earned, negative = redeemed
  type        String   // EARNED | REDEEMED | EXPIRED | BIRTHDAY_BONUS | ANNIVERSARY_BONUS
  description String?
  invoiceId   String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id          String              @id @default(cuid())
  type        String              // APPOINTMENT_REMINDER | BIRTHDAY | ANNIVERSARY | MEMBERSHIP_EXPIRY | INVOICE | PROMOTIONAL
  customerId  String?
  staffId     String?
  title       String
  message     String
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  scheduledAt DateTime?
  sentAt      DateTime?
  errorMsg    String?
  metadata    Json?               // extra data like appointment ID, etc.
  createdAt   DateTime            @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([scheduledAt])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // CREATE | UPDATE | DELETE | LOGIN | LOGOUT | PRINT | EXPORT
  entity    String   // Customer | Invoice | Appointment | Product | etc.
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// SALON SETTINGS
// ─────────────────────────────────────────────

model PettyCashEntry {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  voucherNo   String   @unique
  description String
  category    String
  type        String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model SalonSettings {
  id                      String   @id @default(cuid())
  salonName               String   @default("Elysian Salon")
  tagline                 String?
  address                 String?
  phone                   String?
  phone2                  String?
  email                   String?
  gstin                   String?
  logo                    String?
  currency                String   @default("INR")
  currencySymbol          String   @default("₹")
  cgstRate                Decimal  @default(9) @db.Decimal(5, 2)
  sgstRate                Decimal  @default(9) @db.Decimal(5, 2)
  openingTime             String   @default("09:00")
  closingTime             String   @default("20:00")
  workingDays             String[] @default(["MON", "TUE", "WED", "THU", "FRI", "SAT"])
  appointmentSlotMins     Int      @default(30)
  loyaltyPointsPerRupee   Decimal  @default(1) @db.Decimal(5, 2)
  loyaltyRupeePerPoint    Decimal  @default(0.5) @db.Decimal(5, 2)
  loyaltyMinRedemption    Int      @default(100)
  pettyCashOpeningBalance Decimal  @default(0) @db.Decimal(10, 2)
  whatsappEnabled        Boolean  @default(false)
  whatsappPhoneNumberId  String?
  smsEnabled             Boolean  @default(false)
  emailEnabled           Boolean  @default(false)
  autoReminderHours      Int      @default(24) // send reminder N hours before
  invoicePrefix          String   @default("INV")
  appointmentPrefix      String   @default("APT")
  customerPrefix         String   @default("CUS")
  employeePrefix         String   @default("EMP")
  receiptFooter          String?
