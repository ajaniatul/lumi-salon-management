# Database
DATABASE_URL="postgresql://user:password@localhost:5432/salon_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SALON_NAME="Elysian Salon"

# Cloudinary (file/image storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# WhatsApp Business API (Meta)
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
WHATSAPP_ACCESS_TOKEN="your-access-token"
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# SMS (optional - Twilio or MSG91)
SMS_PROVIDER="msg91"
MSG91_AUTH_KEY="your-msg91-key"
MSG91_SENDER_ID="SALON"
MSG91_TEMPLATE_ID="your-template-id"

# Email (optional - Resend or Nodemailer)
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="noreply@yoursalon.com"

# Encryption
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Node environment
NODE_ENV="development"
